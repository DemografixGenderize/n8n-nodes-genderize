{
  "name": "@demografix/n8n-nodes-genderize",
  "version": "1.1.0",
  "description": "n8n community node for Genderize.io API - predict gender based on first names with probability scores",
  "license": "MIT",
  "homepage": "https://github.com/DemografixGenderize/n8n-nodes-genderize#readme",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "genderize",
    "gender",
    "demographics",
    "api"
  ],
  "author": {
    "name": "Demografix",
    "email": "info@genderize.io"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/DemografixGenderize/n8n-nodes-genderize.git"
  },
  "scripts": {
    "build": "n8n-node build",
    "build:watch": "tsc --watch",
    "dev": "n8n-node dev",
    "lint": "n8n-node lint",
    "lint:fix": "n8n-node lint --fix",
    "release": "n8n-node release",
    "prepublishOnly": "n8n-node prerelease"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "strict": true,
    "credentials": [
      "dist/credentials/DemografixGenderizeApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/DemografixGenderize/DemografixGenderize.node.js"
    ]
  },
  "devDependencies": {
    "@n8n/node-cli": "*",
    "eslint": "9.32.0",
    "prettier": "3.8.3",
    "release-it": "^20.0.1",
    "typescript": "6.0.3"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
